# Posterior predictive checks
draws_list = as.matrix(mcmc_combined)
n_draws = nrow(draws_list)

# Function to compute p matrix for one draw
compute_p_for_draw = function(draw_row) {
  alphas = as.numeric(draw_row[alpha_names])
  betas  = as.numeric(draw_row[beta_names])
  p_mat = matrix(NA, nrow = nrows, ncol = quality)
  for(i in 1:nrows) {
    eta = ifelse(i==1, 0, betas[i])  
    cum = sapply(1:(quality-1), function(k) plogis(alphas[k] - eta))
    p_vec = numeric(quality)
    p_vec[1] = cum[1]
    for(k in 2:(quality-1)){
      p_vec[k] = cum[k] - cum[k-1]
    }
    p_vec[quality] = 1 - cum[quality-1]
    p_mat[i,] = p_vec
  }
  p_mat
} 
p_accum = matrix(0, nrow = nrows, ncol = quality)
for(d in 1:n_draws) {
  pmat = compute_p_for_draw(draws_list[d,])
  p_accum = p_accum + pmat
}
p_mean = p_accum / n_draws
rownames(p_mean) = paste0("Price", data_wide$Price)
colnames(p_mean) = paste0("Q", 0:(quality-1))
print(round(p_mean,3))

# Compute probability that Higher priced beer has stochastically higher rating
get_expected_scores = function(draw_row) {
  pmat = compute_p_for_draw(draw_row)
  scores = 0:(quality-1)
  expected = pmat %*% scores
  as.numeric(expected)
}
expectations = t(apply(draws_list, 1, get_expected_scores)) # draws x prices
prob_3_gt_1 = mean(expectations[,3] > expectations[,1])
prob_2_gt_1 = mean(expectations[,2] > expectations[,1])
prob_3_gt_2 = mean(expectations[,3] > expectations[,2])
print(prob_2_gt_1)
print(prob_3_gt_1)
print(prob_3_gt_2)

