# JAGS model
jags_model = "
model {
  for(i in 1:nrow) {
    y[i,1:K] ~ dmulti(p[i,], N[i])
    eta[i] = beta[price[i]]  
    for(k in 1:(K-1)) {
      cumprob[i,k] = ilogit(alpha[k] - eta[i])
    }
    p[i,1] = cumprob[i,1]
    for(k in 2:(K-1)) {
      p[i,k] = max(0, cumprob[i,k] - cumprob[i,k-1])
    }
    p[i,K] = max(0, 1 - cumprob[i,K-1])
  }

  # Priors
  beta[1] = 0
  for(j in 2:nprice) {
    beta[j] ~ dnorm(0, 0.001)
  }

  alpha[1] ~ dnorm(0, 0.001)
  for(t in 2:(K-1)) {
    delta[t] ~ dgamma(1.0, 1.0)
    alpha[t] = alpha[t-1] + delta[t]
  }

  for(i in 1:nrow) {
    yrep[i,1:K] ~ dmulti(p[i,], N[i])
  }
}
"

jags_data <- list(
  y = y_mat,
  N = Nvec,
  nrow = nrows,
  K = quality,
  nprice = nrows,
  price = price_index
)

params = c("alpha", "beta", "yrep")

model = jags.model(
  textConnection(jags_model),
  data = jags_data,
  n.chains = 4,
  quiet = FALSE
)
update(model, 1000)  

mcmc_samples = coda.samples(model, variable.names = params, n.iter = 8000, thin = 4)

print(gelman.diag(mcmc_samples, multivariate=FALSE))
summary_stats = summary(mcmc_samples)
